{
  "@context": {
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "behaverse": "https://behaverse.org/schemas/dataset#",
    "bidsparticipants": "https://bids-specification.readthedocs.io/en/stable/modality-agnostic-files.html#",
    "bidssession": "https://bids-specification.readthedocs.io/en/stable/common-principles.html#",
    "cdisc": "https://www.cdisc.org/standards/foundational/sdtm#",
    "cogatlas": "http://www.cognitiveatlas.org/",
    "ct": "https://clinicaltrials.gov/data-api/about-api/schema#",
    "dataset": "https://behaverse.org/schemas/dataset#",
    "dc": "http://purl.org/dc/terms/",
    "ddiuniverse": "https://ddialliance.org/Specification/DDI-Lifecycle/3.3/XMLSchema/FieldLevelDocumentation/schemas/datacollection_xsd/elements/",
    "hf": "https://huggingface.co/docs/hub/datasets-cards#",
    "linkml": "https://w3id.org/linkml/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "@vocab": "https://behaverse.org/schemas/dataset#",
    "is_free": {
      "@type": "xsd:boolean",
      "@id": "is_free"
    },
    "requirements": {
      "@id": "requirements"
    },
