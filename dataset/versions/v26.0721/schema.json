{
  "$defs": {
    "AccessConditions": {
      "additionalProperties": false,
      "description": "Access requirements and restrictions for a dataset.",
      "properties": {
        "is_free": {
          "description": "Whether the dataset is freely accessible without cost",
          "type": [
            "boolean",
            "null"
          ],
          "title": "Is Free"
        },
        "requirements": {
          "description": "Access restrictions or requirements (e.g., registration, data use agreement)",
          "type": [
            "string",
            "null"
          ],
          "title": "Requirements"
        }
      },
      "title": "AccessConditions",
      "type": "object"
    },
    "Activity": {
      "additionalProperties": false,
      "description": "An activity or task performed by participants, with associated measurements.",
      "properties": {
        "conditions": {
          "description": "Experimental conditions",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Conditions"
        },
        "constructs": {
          "description": "Constructs measured",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Constructs"
        },
        "duration": {
          "description": "Typical duration in minutes",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Duration"
        },
        "measurements": {
          "description": "List of measurement techniques collected during this activity (reference by technique name)",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Measurements"
        },
        "measures": {
          "description": "Primary dependent variables",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Measures"
        },
        "name": {
          "description": "Activity/task name",
          "type": "string",
          "title": "Name"
        },
        "trials": {
          "description": "Number of trials",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ],
          "title": "Trials"
        },
        "type": {
          "$ref": "#/$defs/ActivityType",
          "description": "Activity type/category",
          "title": "Type"
        }
      },
      "required": [
        "name"
      ],
      "title": "Activity",
      "type": "object"
    },
    "ActivityType": {
      "description": "Activity type/category",
      "enum": [
        "task",
        "rest",
        "stimulus-presentation",
        "free-viewing",
        "interview",
        "other"
      ],
      "title": "ActivityType",
      "type": "string"
    },
    "AgeCategory": {
      "description": "Age group classification",
      "enum": [
        "children",
        "adolescent",
        "adult",
        "elderly"
      ],
      "title": "AgeCategory",
      "type": "string"
    },
    "Citation": {
      "additionalProperties": false,
      "description": "A published paper or reference associated with a dataset.",
      "properties": {
        "arxiv_id": {
          "description": "ArXiv preprint ID",
          "type": [
            "string",
            "null"
          ],
          "title": "Arxiv Id"
        },
        "doi": {
          "description": "DOI of cited paper",
          "type": [
            "string",
            "null"
          ],
          "title": "Doi"
        },
        "text": {
          "description": "Full citation text",
          "type": [
            "string",
            "null"
          ],
          "title": "Text"
        },
        "type": {
          "$ref": "#/$defs/CitationType",
          "description": "Citation type",
          "title": "Type"
        },
        "url": {
          "description": "URL of cited resource",
          "type": [
            "string",
            "null"
          ],
          "title": "Url"
        }
      },
      "title": "Citation",
      "type": "object"
    },
    "CitationType": {
      "description": "Citation type",
      "enum": [
        "primary",
        "methods",
        "related",
        "preprint"
      ],
      "title": "CitationType",
      "type": "string"
    },
    "Dataset": {
      "additionalProperties": false,
      "description": "A metadata record for a cognitive science or neuroscience dataset.",
      "properties": {
        "access_conditions": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccessConditions"
            },
            {
              "type": "null"
            }
          ],
          "description": "Access requirements and restrictions for the dataset",
          "title": "Access Conditions"
        },
        "access_url": {
          "description": "URL to dataset landing page with documentation, access instructions, and metadata (not direct download)",
          "type": [
            "string",
            "null"
          ],
          "title": "Access Url"
        },
        "activity": {
          "description": "Activities or tasks performed by participants with associated measurements",
          "items": {
            "$ref": "#/$defs/Activity"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Activity"
        },
        "age_category": {
          "description": "Age group classification",
          "items": {
            "$ref": "#/$defs/AgeCategory"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Age Category"
        },
        "age_mean": {
          "description": "Mean participant age",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Age Mean"
        },
        "age_range": {
          "description": "[min, max] age in years",
          "items": {
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": [
            "array",
            "null"
          ],
          "title": "Age Range"
        },
        "age_std": {
          "description": "Standard deviation of age",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Age Std"
        },
        "citation": {
          "description": "Published papers or references",
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Citation"
        },
        "constructs_measured": {
          "description": "Cognitive or psychological constructs measured in the dataset",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Constructs Measured"
        },
        "creator": {
          "description": "Primary dataset creators/authors",
          "items": {
            "$ref": "#/$defs/Person"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Creator"
        },
        "curator": {
          "description": "Dataset curators responsible for maintenance and quality",
          "items": {
            "$ref": "#/$defs/Person"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Curator"
        },
        "data_formats": {
          "description": "File formats (csv, json, edf, etc.)",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Data Formats"
        },
        "data_size_gb": {
          "description": "Total dataset size (GB)",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Data Size Gb"
        },
        "data_structure": {
          "description": "Organization of data files",
          "type": [
            "string",
            "null"
          ],
          "title": "Data Structure"
        },
        "date_added": {
          "description": "Date added to catalog (ISO 8601, internal)",
          "format": "date",
          "type": "string",
          "title": "Date Added"
        },
        "date_created": {
          "description": "Date dataset was originally created (ISO 8601)",
          "format": "date",
          "type": [
            "string",
            "null"
          ],
          "title": "Date Created"
        },
        "date_modified": {
          "description": "Date of last modification (ISO 8601)",
          "format": "date",
          "type": [
            "string",
            "null"
          ],
          "title": "Date Modified"
        },
        "date_published": {
          "description": "Date first published (ISO 8601)",
          "format": "date",
          "type": [
            "string",
            "null"
          ],
          "title": "Date Published"
        },
        "description": {
          "description": "Comprehensive dataset description",
          "pattern": "^[\\s\\S]{10,}$",
          "type": "string",
          "title": "Description"
        },
        "doi": {
          "description": "Digital Object Identifier",
          "pattern": "^10\\.\\d{4,}/[-._;()/:A-Za-z0-9]+$",
          "type": [
            "string",
            "null"
          ],
          "title": "Doi"
        },
        "download_url": {
          "description": "Direct URL to download dataset files (e.g., .zip archive or direct file download)",
          "type": [
            "string",
            "null"
          ],
          "title": "Download Url"
        },
        "ethical_approval": {
          "anyOf": [
            {
              "$ref": "#/$defs/EthicalApproval"
            },
            {
              "type": "null"
            }
          ],
          "description": "Ethical approval and IRB information",
          "title": "Ethical Approval"
        },
        "exclusion_criteria": {
          "description": "Participant exclusion criteria",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Exclusion Criteria"
        },
        "inclusion_criteria": {
          "description": "Participant inclusion criteria",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Inclusion Criteria"
        },
        "intervention_type": {
          "description": "Type(s) of intervention (applies when study_design_type is intervention)",
          "items": {
            "$ref": "#/$defs/InterventionType"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Intervention Type"
        },
        "keywords": {
          "description": "Keywords for discovery",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": [
            "array",
            "null"
          ],
          "title": "Keywords"
        },
        "language": {
          "description": "ISO 639-1 language codes",
          "items": {
            "pattern": "^[a-z]{2}$",
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Language"
        },
        "last_verified": {
          "description": "Date metadata was last verified (ISO 8601, internal)",
          "format": "date",
          "type": [
            "string",
            "null"
          ],
          "title": "Last Verified"
        },
        "license": {
          "$ref": "#/$defs/License",
          "description": "License identifier in SPDX format",
          "title": "License"
        },
        "measurement_technique": {
          "description": "Measurement techniques used with optional detailed specifications",
          "items": {
            "$ref": "#/$defs/MeasurementTechnique"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Measurement Technique"
        },
        "name": {
          "description": "Short URL-friendly identifier",
          "pattern": "^[a-z0-9_-]+$",
          "type": "string",
          "title": "Name"
        },
        "population_category": {
          "$ref": "#/$defs/PopulationCategory",
          "description": "Population type (clinical vs healthy)",
          "title": "Population Category"
        },
        "pretty_name": {
          "description": "Human-readable display title",
          "type": [
            "string",
            "null"
          ],
          "title": "Pretty Name"
        },
        "sample_size": {
          "description": "Total number of participants",
          "minimum": 1,
          "type": "integer",
          "title": "Sample Size"
        },
        "session_count": {
          "description": "Number of experimental sessions per participant",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ],
          "title": "Session Count"
        },
        "session_description": {
          "description": "Brief description of session structure (if multi-session)",
          "type": [
            "string",
            "null"
          ],
          "title": "Session Description"
        },
        "sex_distribution": {
          "anyOf": [
            {
              "$ref": "#/$defs/SexDistribution"
            },
            {
              "type": "null"
            }
          ],
          "description": "Participant counts by sex",
          "title": "Sex Distribution"
        },
        "size_category": {
          "$ref": "#/$defs/SizeCategory",
          "description": "HF size bucket",
          "title": "Size Category"
        },
        "spatial_coverage": {
          "description": "Geographic location/region",
          "type": [
            "string",
            "null"
          ],
          "title": "Spatial Coverage"
        },
        "study_design_type": {
          "$ref": "#/$defs/StudyDesignType",
          "description": "Study design category",
          "title": "Study Design Type"
        },
        "task_categories": {
          "description": "ML task types",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Task Categories"
        },
        "temporal_coverage": {
          "description": "Time period data covers",
          "type": [
            "string",
            "null"
          ],
          "title": "Temporal Coverage"
        },
        "url": {
          "description": "Dataset homepage or landing page",
          "type": [
            "string",
            "null"
          ],
          "title": "Url"
        },
        "version": {
          "description": "Dataset version (semantic versioning)",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "type": [
            "string",
            "null"
          ],
          "title": "Version"
        }
      },
      "required": [
        "name",
        "description",
        "license",
        "date_added",
        "sample_size"
      ],
      "title": "Dataset",
      "type": "object"
    },
    "EthicalApproval": {
      "additionalProperties": false,
      "description": "Ethical approval and IRB information.",
      "properties": {
        "institution": {
          "description": "IRB or ethics board institution",
          "type": [
            "string",
            "null"
          ],
          "title": "Institution"
        },
        "obtained": {
          "description": "Whether ethics approval was obtained",
          "type": [
            "boolean",
            "null"
          ],
          "title": "Obtained"
        },
        "protocol": {
          "description": "Protocol or approval number",
          "type": [
            "string",
            "null"
          ],
          "title": "Protocol"
        }
      },
      "title": "EthicalApproval",
      "type": "object"
    },
    "Granularity": {
      "description": "Granularity of the measurement",
      "enum": [
        "event-data",
        "timecourse-data",
        "trial-data",
        "construct-data",
        "aggregate-data"
      ],
      "title": "Granularity",
      "type": "string"
    },
    "InterventionType": {
      "description": "Type of intervention",
      "enum": [
        "behavioral",
        "pharmacological",
        "device",
        "procedure",
        "other"
      ],
      "title": "InterventionType",
      "type": "string"
    },
    "License": {
      "description": "License identifier in SPDX format",
      "enum": [
        "CC-BY-4.0",
        "CC-BY-SA-4.0",
        "CC-BY-NC-4.0",
        "CC-BY-NC-SA-4.0",
        "CC0-1.0",
        "MIT",
        "Apache-2.0",
        "GPL-3.0-only",
        "other"
      ],
      "title": "License",
      "type": "string"
    },
    "MeasurementCategory": {
      "description": "High-level category of measurement",
      "enum": [
        "behavior",
        "neuroimaging",
        "electrophysiology",
        "physiological",
        "video",
        "audio",
        "other"
      ],
      "title": "MeasurementCategory",
      "type": "string"
    },
    "MeasurementTechnique": {
      "additionalProperties": false,
      "description": "A measurement technique used in a dataset, with optional detailed specifications.",
      "properties": {
        "channels": {
          "description": "Number of channels/electrodes (for EEG, MEG)",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ],
          "title": "Channels"
        },
        "details": {
          "description": "Additional technique-specific details",
          "type": [
            "string",
            "null"
          ],
          "title": "Details"
        },
        "field_strength": {
          "description": "Magnetic field strength in Tesla (for MRI)",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Field Strength"
        },
        "format": {
          "description": "File format for this specific measurement (e.g., edf, bdf, nii, csv)",
          "type": [
            "string",
            "null"
          ],
          "title": "Format"
        },
        "granularity": {
          "$ref": "#/$defs/Granularity",
          "description": "Granularity of the measurement (e.g., per trial, per subject, per session)",
          "title": "Granularity"
        },
        "manufacturer": {
          "description": "Equipment manufacturer/system",
          "type": [
            "string",
            "null"
          ],
          "title": "Manufacturer"
        },
        "reference": {
          "description": "Reference type (for EEG, MEG)",
          "type": [
            "string",
            "null"
          ],
          "title": "Reference"
        },
        "response_modality": {
          "description": "Response input modalities used (applies when technique is behavior)",
          "items": {
            "$ref": "#/$defs/ResponseModality"
          },
          "type": [
            "array",
            "null"
          ],
          "title": "Response Modality"
        },
        "sampling_rate": {
          "description": "Sampling rate in Hz (for EEG, MEG, physiological)",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Sampling Rate"
        },
        "te": {
          "description": "Echo time in ms (for MRI)",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Te"
        },
        "technique": {
          "$ref": "#/$defs/MeasurementTechniqueType",
          "description": "Specific measurement technique",
          "title": "Technique"
        },
        "tr": {
          "description": "Repetition time in ms (for fMRI)",
          "minimum": 0,
          "type": [
            "number",
            "null"
          ],
          "title": "Tr"
        },
        "type": {
          "$ref": "#/$defs/MeasurementCategory",
          "description": "High-level category of measurement",
          "title": "Type"
        }
      },
      "required": [
        "technique"
      ],
      "title": "MeasurementTechnique",
      "type": "object"
    },
    "MeasurementTechniqueType": {
      "description": "Specific measurement technique",
      "enum": [
        "EEG",
        "MEG",
        "iEEG",
        "fMRI",
        "T1w",
        "T2w",
        "DWI",
        "ASL",
        "PET",
        "NIRS",
        "behavior",
        "voice",
        "eye-tracking",
        "key-presses",
        "mouse-tracking",
        "motion-capture",
        "video",
        "audio",
        "heart-rate",
        "GSR",
        "EDA",
        "ECG",
        "EMG",
        "other"
      ],
      "title": "MeasurementTechniqueType",
      "type": "string"
    },
    "Person": {
      "additionalProperties": false,
      "description": "A person (creator or curator) associated with a dataset.",
      "properties": {
        "affiliation": {
          "description": "Institutional affiliation",
          "type": [
            "string",
            "null"
          ],
          "title": "Affiliation"
        },
        "email": {
          "description": "Email address",
          "pattern": "^\\S+@\\S+\\.\\S+$",
          "type": [
            "string",
            "null"
          ],
          "title": "Email"
        },
        "name": {
          "description": "Full name of the person",
          "type": "string",
          "title": "Name"
        },
        "orcid": {
          "description": "ORCID identifier",
          "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$",
          "type": [
            "string",
            "null"
          ],
          "title": "Orcid"
        }
      },
      "required": [
        "name"
      ],
      "title": "Person",
      "type": "object"
    },
    "PopulationCategory": {
      "description": "Population type (clinical vs healthy)",
      "enum": [
        "healthy",
        "clinical",
        "patient",
        "mixed"
      ],
      "title": "PopulationCategory",
      "type": "string"
    },
    "ResponseModality": {
      "description": "Response input modalities — the device/action through which responses are given (cf. the trial schema's `input_action_type`). Distinct from the trial schema's `response_type`, which names the FORM of the answer (choice, rating, production, ...).",
      "enum": [
        "button-press",
        "key-press",
        "mouse",
        "voice",
        "eye-gaze",
        "touchscreen"
      ],
      "title": "ResponseModality",
      "type": "string"
    },
    "SexDistribution": {
      "additionalProperties": false,
      "description": "Participant counts by sex.",
      "properties": {
        "female": {
          "description": "Number of female participants",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ],
          "title": "Female"
        },
        "male": {
          "description": "Number of male participants",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ],
          "title": "Male"
        },
        "not_reported": {
          "description": "Number of participants who did not report gender",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ],
          "title": "Not Reported"
        },
        "other": {
          "description": "Number of participants with other gender identity",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ],
          "title": "Other"
        }
      },
      "title": "SexDistribution",
      "type": "object"
    },
    "SizeCategory": {
      "description": "HuggingFace size bucket",
      "enum": [
        "n<1K",
        "1K<n<10K",
        "10K<n<100K",
        "100K<n<1M",
        "1M<n<10M",
        "10M<n<100M",
        "100M<n<1B",
        "1B<n<10B",
        "10B<n<100B",
        "100B<n<1T",
        "n>1T"
      ],
      "title": "SizeCategory",
      "type": "string"
    },
    "StudyDesignType": {
      "description": "Study design category",
      "enum": [
        "cross-sectional",
        "longitudinal",
        "intervention",
        "observational"
      ],
      "title": "StudyDesignType",
      "type": "string"
    }
  },
  "$id": "https://behaverse.org/schemas/dataset/v26.0721/schema.json",
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "additionalProperties": true,
  "description": "A metadata record for a cognitive science or neuroscience dataset.",
  "metamodel_version": "1.7.0",
  "properties": {
    "@type": {
      "const": "schema:Dataset",
      "title": "Type",
      "description": "JSON-LD node type (rdf:type) for schema.org / Google Dataset Search discoverability."
    },
    "access_conditions": {
      "anyOf": [
        {
          "$ref": "#/$defs/AccessConditions"
        },
        {
          "type": "null"
        }
      ],
      "description": "Access requirements and restrictions for the dataset",
      "title": "Access Conditions"
    },
    "access_url": {
      "description": "URL to dataset landing page with documentation, access instructions, and metadata (not direct download)",
      "type": [
        "string",
        "null"
      ],
      "title": "Access Url"
