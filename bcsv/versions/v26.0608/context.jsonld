{
  "@context": {
    "@vocab": "https://behaverse.org/schemas/bcsv#",
    "bcsv": "https://behaverse.org/schemas/bcsv#",
    "csvw": "http://www.w3.org/ns/csvw#",
    "dc": "http://purl.org/dc/terms/",
    "schema": "http://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    
    "description": {
      "@id": "dc:description"
    },
    "pretty_name": {
      "@id": "dc:title"
    },
    "date_created": {
      "@id": "schema:dateCreated",
      "@type": "xsd:date"
    },
    "creator": {
      "@id": "schema:creator"
    },
    "email": {
      "@id": "schema:email"
    },
    "orcid": {
      "@id": "schema:identifier"
    },
    "affiliation": {
      "@id": "schema:affiliation"
    },

    "string":      "xsd:string",
    "integer":     "xsd:integer",
    "number":      "xsd:double",
    "boolean":     "xsd:boolean",
    "date":        "xsd:date",
    "datetime":    "xsd:dateTime",
    "time":        "xsd:time",
    "categorical": "bcsv:categorical",
    "ordered":     "bcsv:ordered",

    "levels": {
      "@id": "https://behaverse.org/schemas/bcsv#levels",
      "@container": "@list"
    },
    "na_strings": {
      "@id": "https://behaverse.org/schemas/bcsv#na_strings",
      "@container": "@list"
    },
    "unit": {
      "@id": "https://behaverse.org/schemas/bcsv#unit"
    },
    "file_hash": {
      "@id": "https://behaverse.org/schemas/bcsv#file_hash"
    },
    "license": "schema:license",
    "label": "rdfs:label",
    "min_length": {
      "@id": "csvw:minLength",
      "@type": "xsd:nonNegativeInteger"
    },
    "max_length": {
      "@id": "csvw:maxLength",
      "@type": "xsd:nonNegativeInteger"
    },
    
    "Table": "csvw:Table",
    "Schema": "csvw:Schema",
    "Column": "csvw:Column",
    "Datatype": "csvw:Datatype",
    
    "table_schema": {
      "@id": "csvw:tableSchema",
      "@type": "@id"
    },
    "columns": {
      "@id": "csvw:column",
      "@type": "@id",
      "@container": "@list"
    },
    "datatype": {
      "@id": "csvw:datatype",
      "@type": "@vocab"
    },
    "name": "csvw:name",
    "propertyUrl": {
      "@id": "csvw:propertyUrl",
      "@type": "@id"
    },
    "valueUrl": {
      "@id": "csvw:valueUrl",
      "@type": "@id"
    },
    "aboutUrl": {
      "@id": "csvw:aboutUrl",
      "@type": "@id"
    },
    "url": {
      "@id": "csvw:url",
      "@type": "@id"
    },
    "null": "csvw:null",
    "default": "csvw:default",
    "separator": "csvw:separator",
    "virtual": {
      "@id": "csvw:virtual",
      "@type": "xsd:boolean"
    },
    "suppressOutput": {
      "@id": "csvw:suppressOutput",
      "@type": "xsd:boolean"
    },
    "required": {
      "@id": "csvw:required",
      "@type": "xsd:boolean"
    },
    "primary_key": "csvw:primaryKey",
    "foreignKeys": {
      "@id": "csvw:foreignKey",
      "@container": "@list"
    },
    "rowTitles": "csvw:rowTitle",
    "base": "csvw:base",
    "format": "csvw:format",
    "minimum": "csvw:minInclusive",
    "maximum": "csvw:maxInclusive",
    "length": {
      "@id": "csvw:length",
      "@type": "xsd:nonNegativeInteger"
    }
  }
}
