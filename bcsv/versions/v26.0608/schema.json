{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://behaverse.org/schemas/bcsv/v26.0608/schema.json",
  "title": "BCSV Table Schema",
  "description": "JSON Schema for BCSV (Behaverse CSV) metadata files",
  "version": "26.0608",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string",
      "description": "JSON-LD context URL",
      "default": "https://behaverse.org/schemas/bcsv/context.jsonld"
    },
    "@type": {
      "const": "csvw:Table",
      "description": "JSON-LD node type (rdf:type). A bcsv document describes a CSVW table."
    },
    "name": {
      "type": "string",
      "description": "Short URL-friendly identifier",
      "pattern": "^[a-z0-9-_]+$"
    },
    "url": {
      "type": "string",
      "description": "URL or path to the CSV file"
    },
    "dialect": {
      "type": "object",
      "description": "CSV serialization hints. v0 honors `delimiter` and `encoding`; other CSVW dialect sub-properties pass through but are not interpreted by bcsv tooling.",
      "properties": {
        "delimiter": {
          "type": "string",
          "description": "Field separator. Common values: ',', ';', '\\t'.",
          "minLength": 1,
          "maxLength": 1
        },
        "encoding": {
          "type": "string",
          "description": "Character encoding (IANA name). Default UTF-8.",
          "examples": ["UTF-8", "windows-1252", "ISO-8859-1"]
        }
      },
      "additionalProperties": true
    },
    "pretty_name": {
      "type": "string",
      "description": "Human-readable title for the table"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the table contents"
    },
    "date_created": {
      "type": "string",
      "format": "date",
      "description": "Date the table was created"
    },
    "creator": {
      "oneOf": [
        {
          "type": "string",
          "description": "Person or organization name (simple format)"
        },
        {
          "$ref": "#/definitions/creator_object",
          "description": "Single structured creator"
        },
        {
          "type": "array",
          "description": "Multiple structured creators",
          "items": { "$ref": "#/definitions/creator_object" }
        }
      ],
      "description": "Person or organization that created the table (string, object, or array of objects)"
    },
    "file_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the CSV file for integrity verification (lowercase hex)"
    },
    "license": {
      "type": "string",
      "description": "License identifier in SPDX format (e.g., CC-BY-4.0, MIT, Apache-2.0)"
    },
    "table_schema": {
      "type": "object",
      "description": "Schema describing the structure and properties of columns in the CSV table",
      "required": ["columns"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/column"
          }
        },
        "primary_key": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Column name(s) that form the primary key. Snake_case because bcsv actively validates this (composite uniqueness); see README for the CSVW-vs-bcsv naming principle."
        }
      }
    }
  },
  "required": ["@context", "url", "description", "table_schema"],
  "definitions": {
    "creator_object": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Creator full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Creator email address"
        },
        "orcid": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$",
          "description": "ORCID identifier"
        },
        "affiliation": {
          "type": "string",
          "description": "Institutional affiliation"
        }
      }
    },
    "column": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Column name (must match CSV header)"
        },
        "label": {
          "type": "string",
          "description": "Human-readable label"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the column"
        },
        "datatype": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean", "date", "datetime", "time", "categorical", "ordered"],
          "description": "Data type of the column"
        },
        "format": {
          "type": "string",
          "description": "Format pattern or constraint for values (forbidden when datatype is categorical or ordered)"
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement (e.g., 'kg', '°C', 'mol/L')"
        },
        "levels": {
          "type": "array",
          "items": {
            "type": ["string", "number"]
          },
          "description": "Factor levels for categorical or ordered datatypes (strings or numbers; integers count as numbers)"
        },
        "minimum": {
          "type": "number",
          "description": "Minimum value for numeric columns"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum value for numeric columns"
        },
        "min_length": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum string length"
        },
        "max_length": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum string length"
        },
        "null": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "String(s) representing null values"
        },
        "na_strings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional missing value codes"
        },
        "required": {
          "type": "boolean",
          "description": "Whether column values are required (not null)"
        },
        "virtual": {
          "type": "boolean",
          "description": "Whether column is virtual (not in CSV)"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["datatype"],
            "properties": { "datatype": { "enum": ["categorical", "ordered"] } }
          },
          "then": {
            "required": ["levels"],
            "not": { "required": ["format"] }
          }
        },
        {
          "if": {
            "anyOf": [
              { "not": { "required": ["datatype"] } },
              { "properties": { "datatype": { "not": { "enum": ["categorical", "ordered"] } } } }
            ]
          },
          "then": {
            "not": { "required": ["levels"] }
          }
        },
        {
          "if": {
            "anyOf": [
              { "not": { "required": ["datatype"] } },
              { "properties": { "datatype": { "not": { "enum": ["integer", "number"] } } } }
            ]
          },
          "then": {
            "allOf": [
              { "not": { "required": ["minimum"] } },
              { "not": { "required": ["maximum"] } }
            ]
          }
        },
        {
          "if": {
            "required": ["datatype"],
            "properties": { "datatype": { "not": { "enum": ["string"] } } }
          },
          "then": {
            "allOf": [
              { "not": { "required": ["min_length"] } },
              { "not": { "required": ["max_length"] } }
            ]
          }
        }
      ]
    }
  }
}
